# Runtime
NODE_ENV=development
PORT=8787
DATA_DIR=data
DEV_BYPASS_EMAIL_VERIFY=false
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_LEADS_PER_MINUTE=20
RATE_LIMIT_WEBHOOKS_PER_MINUTE=120

# URLs and CORS
FRONTEND_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=

# Email (Brevo)
BREVO_API_KEY=
EMAIL_FROM=
DEMO_LEAD_NOTIFY_EMAIL=kufuchatbot@gmail.com
CONTACT_LEAD_NOTIFY_EMAIL=kufuchatbot@gmail.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp / Meta
WHATSAPP_GRAPH_API_VERSION=v22.0
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v22.0
META_REDIRECT_URI=
META_EMBEDDED_SIGNUP_CONFIG_ID=
WHATSAPP_WEBHOOK_ALLOWED_IPS=

# Widget defaults (optional)
DEFAULT_WIDGET_LOGO_PATH=
DEFAULT_WIDGET_LOGO_URL=

# RAG crawler tuning (optional)
ENABLE_PLAYWRIGHT=false
RAG_JS_RENDER_TIMEOUT_MS=15000
JINA_API_KEY=
